# Application Settings
APP_NAME=SentiMedical-RAG
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=medical_documents
QDRANT_KB_COLLECTION_NAME=medical_knowledge_base
QDRANT_USER_COLLECTION_NAME=user_documents
QDRANT_VECTOR_SIZE=1024

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Sentiment Analysis
SENTIMENT_MODEL=j-hartmann/emotion-english-distilroberta-base
SENTIMENT_DEVICE=cpu

# NER Model
NER_MODEL=en_core_med7_lg
SPACY_MODEL=en_core_web_sm

# LangGraph / LangChain
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=SentiMedical-RAG

# Monitoring
PHOENIX_HOST=localhost
PHOENIX_PORT=6006
LANGSMITH_API_KEY=

# Evaluation
EVALUATION_ENABLED=true
RAGAS_METRICS=faithfulness,relevancy,answer_correctness

# Safety
SAFETY_ENABLED=true
RISK_THRESHOLD=0.8
MAX_INPUT_LENGTH=5000
MAX_OUTPUT_LENGTH=5000

# Retrieval
HYBRID_SEARCH_ENABLED=true
BM25_K1=1.5
BM25_B=0.75
VECTOR_SEARCH_TOP_K=10
RERANKER_TOP_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Data Paths
DATA_DIR=./data
RAW_DOCUMENTS_DIR=./data/raw
PROCESSED_CHUNKS_DIR=./data/processed/chunks
EMBEDDINGS_CACHE_DIR=./data/embeddings
MODELS_DIR=./models
LOGS_DIR=./logs

# AWS (Optional - for deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Database (Optional - for metadata storage)
DATABASE_URL=sqlite:///./data/sentimedical.db

# Authentication (Optional)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

